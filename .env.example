# ─────────────────────────────────────────────
#  SUPABASE — récupère ces valeurs sur
#  https://supabase.com/dashboard → Settings → API
# ─────────────────────────────────────────────

# URL publique de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co

# Clé publique "anon" (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service-role (JAMAIS exposée côté client — serveur only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─────────────────────────────────────────────
#  OPENAI — pour la génération de fiches produits
#  https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...


# ─────────────────────────────────────────────
#  APP
# ─────────────────────────────────────────────

# URL de base de l'app (utile pour les redirections Supabase Auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
